/* pages/home/home.wxss */
.page {
  min-height: 100vh;
  background: #0D0D0D;
  padding: 20rpx;
}
.header {
  padding: 20rpx 10rpx 40rpx;
}
.date {
  color: #8A8A8A;
  font-size: 28rpx;
  display: block;
  margin-bottom: 8rpx;
}
.greeting {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: bold;
}
.task-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.task-card {
  background: #1A1A1A;
  border: 1px solid #2A2A2A;
  border-radius: 16rpx;
  padding: 24rpx;
}
.source-tag {
  background: #6366F1;
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 12rpx;
}
.task-title {
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}
.task-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.duration {
  color: #8A8A8A;
  font-size: 26rpx;
}
.status {
  font-size: 26rpx;
}
.status.pending { color: #F59E0B; }
.status.completed { color: #22C55E; }
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #8A8A8A;
}
.empty-state .sub {
  font-size: 28rpx;
  margin-top: 16rpx;
  display: block;
}
.reminder-banner {
  background: linear-gradient(135deg, #1A1A1A 0%, #2A2A2A 100%);
  border: 1px solid #6366F1;
  border-radius: 12rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.reminder-banner text {
  color: #FFFFFF;
  font-size: 28rpx;
}
.reminder-banner .close {
  color: #8A8A8A;
  font-size: 40rpx;
}
