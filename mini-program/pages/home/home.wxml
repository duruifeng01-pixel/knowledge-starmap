<!-- pages/home/home.wxml -->
<view class="page">
  <view class="reminder-banner" wx:if="{{showReminder}}" bindtap="disableReminder">
    <text>📬 开启每日提醒</text>
    <text class="close">×</text>
  </view>

  <view class="header">
    <text class="date">{{date}}</text>
    <text class="greeting">{{greeting}}</text>
  </view>

  <view class="task-list">
    <block wx:for="{{tasks}}" wx:key="id">
      <view class="task-card" bindtap="openTask" data-id="{{item.id}}">
        <view class="task-source">
          <text class="source-tag">{{item.sourceType}}</text>
        </view>
        <text class="task-title">{{item.title}}</text>
        <view class="task-meta">
          <text class="duration">约 {{item.estimatedMinutes}} 分钟</text>
          <text class="status {{item.status}}">{{item.statusText}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="empty-state" wx:if="{{tasks.length === 0}}">
    <text>今日任务已全部完成！</text>
    <text class="sub">明天继续点亮新知识</text>
  </view>
</view>
