/* pages/onboarding/onboarding.wxss */
.container {
  min-height: 100vh;
  background: #0D0D0D;
  padding: 40rpx;
}
.title {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 60rpx;
  display: block;
}
.input, .textarea {
  background: #1A1A1A;
  border: 1px solid #2A2A2A;
  color: #FFFFFF;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}
.textarea { height: 200rpx; }
.btn-primary {
  background: #6366F1;
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}