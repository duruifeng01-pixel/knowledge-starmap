/* pages/discussion/discussion.wxss */
.page {
  min-height: 100vh;
  background: #0D0D0D;
  padding: 24rpx;
}
.progress-bar {
  height: 8rpx;
  background: #2A2A2A;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}
.progress-fill {
  height: 100%;
  background: #6366F1;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}
.step-indicator {
  color: #8A8A8A;
  font-size: 26rpx;
  display: block;
  margin-bottom: 32rpx;
}
.question-card {
  background: #1A1A1A;
  border: 1px solid #2A2A2A;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}
.question-text {
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}
.question-hint {
  color: #8A8A8A;
  font-size: 28rpx;
  display: block;
}
.answer-input {
  background: #1A1A1A;
  border: 1px solid #2A2A2A;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  min-height: 200rpx;
  margin-bottom: 24rpx;
}
.btn-submit, .btn-primary {
  background: #6366F1;
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 34rpx;
}
.btn-secondary {
  background: #2A2A2A;
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
}
.nav-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}
